---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE, CATEGORY_SLUGS } from '../../consts';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const categories = [...new Set(posts.map(p => p.data.category).filter(Boolean))] as string[];
	return categories.map(category => ({
		params: { category: CATEGORY_SLUGS[category] || category },
		props: {
			category,
			posts: posts.filter(p => p.data.category === category)
				.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
		},
	}));
}

const { category, posts } = Astro.props;
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`${category} - ${SITE_TITLE}`} description={`${category} 카테고리의 글 목록`} />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<a href="/blog" class="back">&larr; 전체 글</a>
				<h1>{category}</h1>
				<p>{posts.length}개의 글</p>
			</div>
			<div class="posts-grid">
				{posts.map((post) => (
					<a href={`/blog/${post.id}/`} class="post-card">
						{post.data.heroImage && <img src={post.data.heroImage} alt={post.data.title} loading="lazy" />}
						<div class="post-card-body">
							<h3>{post.data.title}</h3>
							<p class="desc">{post.data.description}</p>
							<p class="meta"><FormattedDate date={post.data.pubDate} /></p>
						</div>
					</a>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	main { max-width: 1080px; margin: 0 auto; padding: 2rem 1.5rem; }
	.page-header { margin-bottom: 2rem; }
	.back { font-size: 0.85rem; color: rgb(var(--gray)); text-decoration: none; }
	.back:hover { color: var(--brand); }
	.page-header h1 { font-size: 1.8rem; margin: 0.5rem 0 0.25rem; }
	.page-header p { color: rgb(var(--gray)); font-size: 0.9rem; margin: 0; }
	.posts-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem; }
	.post-card { display: flex; flex-direction: column; background: white; border: 1px solid #e5e7eb; border-radius: 14px; overflow: hidden; text-decoration: none; color: inherit; transition: transform 0.2s, box-shadow 0.2s; }
	.post-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
	.post-card img { width: 100%; height: 200px; object-fit: cover; }
	.post-card-body { padding: 1.25rem; flex: 1; display: flex; flex-direction: column; }
	.post-card h3 { font-size: 1.1rem; margin: 0 0 0.5rem; line-height: 1.4; }
	.post-card .desc { font-size: 0.85rem; color: rgb(var(--gray)); flex: 1; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
	.post-card .meta { font-size: 0.8rem; color: #9ca3af; margin: 0; }
	@media (max-width: 768px) { .posts-grid { grid-template-columns: 1fr; } }
</style>
