---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, category } = Astro.props;
---

<html lang="ko">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<article>
				{heroImage && (
					<div class="hero-image">
						<img src={heroImage} alt={title} />
					</div>
				)}
				<div class="article-header">
					<div class="article-meta">
						{category && <span class="badge">{category}</span>}
						<FormattedDate date={pubDate} />
						{updatedDate && <span class="updated">(수정: <FormattedDate date={updatedDate} />)</span>}
					</div>
					<h1>{title}</h1>
					{description && <p class="article-desc">{description}</p>}
				</div>
				<div class="prose">
					<slot />
				</div>
			</article>

			<div class="article-footer">
				<a href="/blog">&larr; 모든 글 보기</a>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 760px;
		margin: 0 auto;
		padding: 2rem 1.5rem;
	}
	.hero-image {
		margin: 0 -1.5rem 2rem;
	}
	.hero-image img {
		width: 100%;
		max-height: 420px;
		object-fit: cover;
		border-radius: 16px;
	}
	.article-header {
		margin-bottom: 2rem;
	}
	.article-meta {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		font-size: 0.85rem;
		color: rgb(var(--gray));
		margin-bottom: 0.75rem;
	}
	.badge {
		font-size: 0.72rem;
		font-weight: 600;
		padding: 0.15rem 0.6rem;
		border-radius: 20px;
		background: rgba(34, 197, 94, 0.12);
		color: var(--brand);
	}
	.updated {
		font-style: italic;
		font-size: 0.8rem;
	}
	.article-header h1 {
		font-size: 2rem;
		line-height: 1.3;
		margin-bottom: 0.5rem;
	}
	.article-desc {
		color: rgb(var(--gray));
		font-size: 1.05rem;
		line-height: 1.6;
		margin: 0;
	}
	.prose {
		font-size: 1rem;
		line-height: 1.8;
	}
	.prose :global(h2) {
		font-size: 1.4rem;
		margin-top: 2.5rem;
		padding-bottom: 0.4rem;
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.prose :global(h3) {
		font-size: 1.15rem;
		margin-top: 1.75rem;
	}
	.prose :global(ul), .prose :global(ol) {
		padding-left: 1.5rem;
	}
	.prose :global(li) {
		margin-bottom: 0.4rem;
	}
	.article-footer {
		margin-top: 3rem;
		padding-top: 1.5rem;
		border-top: 1px solid rgb(var(--gray-light));
	}
	.article-footer a {
		font-size: 0.9rem;
		font-weight: 500;
		color: var(--brand);
	}
	@media (max-width: 768px) {
		.hero-image { margin: 0 0 1.5rem; }
		.hero-image img { border-radius: 12px; }
		.article-header h1 { font-size: 1.6rem; }
	}
</style>
