---
const year = new Date().getFullYear();
---

<footer>
	<div class="footer-inner">
		<div class="footer-brand">
			<img src="/icon.png" alt="SportsFlow" width="20" height="20" />
			<span>SportsFlow 블로그</span>
		</div>
		<div class="footer-links">
			<a href="https://sportsflow.co.kr" target="_blank">SportsFlow</a>
			<a href="https://manager.sportsflow.co.kr" target="_blank">주최자</a>
			<a href="https://www.instagram.com/sportsflow.co.kr/" target="_blank">Instagram</a>
		</div>
		<p class="copyright">&copy; {year} mint-soft Co.Ltd.</p>
	</div>
</footer>

<style>
	footer {
		border-top: 1px solid #e5e7eb;
		background: white;
		margin-top: 4rem;
	}
	.footer-inner {
		max-width: 1080px;
		margin: 0 auto;
		padding: 2.5rem 1.5rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
	}
	.footer-brand {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		font-weight: 600;
		font-size: 0.9rem;
		color: rgb(var(--gray-dark));
	}
	.footer-brand img {
		border-radius: 4px;
	}
	.footer-links {
		display: flex;
		gap: 1.5rem;
	}
	.footer-links a {
		font-size: 0.85rem;
		color: rgb(var(--gray));
		text-decoration: none;
	}
	.footer-links a:hover {
		color: var(--brand);
	}
	.copyright {
		font-size: 0.8rem;
		color: rgb(var(--gray));
		margin: 0;
	}
</style>
