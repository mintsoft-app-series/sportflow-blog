---
import { SITE_TITLE } from '../consts';
---

<header>
	<div class="header-inner">
		<a href="/" class="logo">
			<img src="/icon.png" alt="SportsFlow" width="28" height="28" />
			<span>{SITE_TITLE}</span>
		</a>
		<nav>
			<a href="/blog">블로그</a>
			<a href="/about">소개</a>
			<a href="https://sportsflow.co.kr" target="_blank" class="cta">SportsFlow</a>
		</nav>
	</div>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 50;
		background: rgba(255, 255, 255, 0.92);
		backdrop-filter: blur(12px);
		border-bottom: 1px solid #e5e7eb;
	}
	.header-inner {
		max-width: 1080px;
		margin: 0 auto;
		padding: 0 1.5rem;
		height: 60px;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.logo {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		text-decoration: none;
		color: rgb(var(--black));
		font-weight: 700;
		font-size: 1.1rem;
	}
	.logo img {
		border-radius: 6px;
	}
	nav {
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}
	nav a {
		padding: 0.4rem 0.8rem;
		border-radius: 8px;
		font-size: 0.9rem;
		font-weight: 500;
		color: rgb(var(--gray-dark));
		text-decoration: none;
		transition: background 0.15s;
	}
	nav a:hover {
		background: #f3f4f6;
		color: rgb(var(--black));
	}
	.cta {
		background: var(--brand) !important;
		color: white !important;
		font-weight: 600;
	}
	.cta:hover {
		background: var(--brand-light) !important;
	}
</style>
